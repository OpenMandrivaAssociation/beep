diff -rupN beep-1.4.12.old/contrib/status-beeps beep-1.4.12/contrib/status-beeps
--- beep-1.4.12.old/contrib/status-beeps	1970-01-01 01:00:00.000000000 +0100
+++ beep-1.4.12/contrib/status-beeps	2026-03-16 10:37:30.188376651 +0100
@@ -0,0 +1,10 @@
+#!/bin/sh
+# Run command and depending on its exit code, produce success or failure beeps
+
+d="$(cd "$(dirname "$0")" && pwd)"
+
+if "$@"; then
+  "$d/success-beeps"
+else
+  "$d/failure-beeps"
+fi
